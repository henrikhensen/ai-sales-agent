# Copy this file to ".env" and adjust as needed. Never commit the real ".env" —
# it is already covered by .gitignore. This file must only ever contain
# placeholder/example values, never real secrets.

# -- Application ------------------------------------------------------------
APP_NAME="AI Sales Agent"
APP_VERSION=0.1.0
# APP_ENV ("environment"): development | staging | production.
# Controls debug verbosity and the CORS wildcard-origin safety warning below.
APP_ENV=development
# DEBUG=true enables SQL echo, verbose (DEBUG-level) logs, and FastAPI's debug
# mode. Always set DEBUG=false in production.
DEBUG=true
# API_V1_PREFIX: URL prefix under which all v1 routes are mounted.
API_V1_PREFIX=/api/v1
# Purely informational (shown in GET /api/v1/system/status and used in
# docs) — does not affect CORS or OAuth redirects, which are configured
# separately below.
FRONTEND_PUBLIC_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8000

# -- PostgreSQL ---------------------------------------------------------------
# The async SQLAlchemy connection URL is derived from these individual
# variables (see backend/shared/config.py: Settings.database_url) so each
# part can be swapped independently.
POSTGRES_USER=sales_agent
POSTGRES_PASSWORD=sales_agent_password
POSTGRES_DB=sales_agent
# Docker Compose service name; use "localhost" when running the backend
# directly on the host against `docker compose up postgres`.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional: if your host injects a single connection string (Render,
# Railway, ...), set DATABASE_URL instead and leave POSTGRES_* as-is —
# DATABASE_URL takes precedence when set. Leave empty for local development.
DATABASE_URL=

# -- Redis ----------------------------------------------------------------
# Same pattern as Postgres: individual variables combine into Settings.redis_url.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Optional full connection string override, analogous to DATABASE_URL above.
REDIS_URL=

# -- LLM / AI Agents --------------------------------------------------------
# LLM_PROVIDER selects the backend: "mock" (default, fully offline, no cost)
# or "anthropic" (real model calls, incurs API cost).
LLM_PROVIDER=mock
# Only required when LLM_PROVIDER=anthropic. Leave empty otherwise.
# NEVER commit a real key here or anywhere else in the repository. A Claude
# Code / Claude.ai subscription does NOT include Anthropic API usage — this
# needs a separate Anthropic API key with its own billing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# Safety switch: even with LLM_PROVIDER=anthropic and ANTHROPIC_API_KEY set,
# no real (billable) API call is ever made unless this is explicitly "true".
# Leave "false" for local development and demos. See README section
# "Echte LLM API sicher aktivieren" before ever setting this to true.
LLM_ENABLE_REAL_CALLS=false
# Input prompts longer than this are truncated before being sent to
# Anthropic (mock provider ignores this).
LLM_MAX_INPUT_CHARS=12000
# Caps the response size (and cost) of a single real Anthropic call.
LLM_MAX_OUTPUT_TOKENS=1200
# How long the backend waits for an Anthropic response before giving up.
LLM_REQUEST_TIMEOUT_SECONDS=30

# -- Frontend / CORS ----------------------------------------------------------
# Comma-separated list of origins allowed to call this API from a browser.
# Must NOT be "*" in production — the backend logs a warning at startup if
# APP_ENV=production and this is left wildcarded.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -- Auth (local JWT) ---------------------------------------------------------
# No external auth provider and no OAuth in this phase — accounts, password
# hashing, and JWT access tokens are fully local to this backend.
# JWT_SECRET_KEY signs access tokens. The default below is a placeholder for
# local development ONLY — generate a real random secret for anything beyond
# a local sandbox (e.g. `openssl rand -hex 32`) and NEVER commit the real
# value. The backend logs a warning at startup if this default is still set
# while APP_ENV=production.
JWT_SECRET_KEY=dev-only-insecure-secret-change-me
JWT_ALGORITHM=HS256
# How long an access token stays valid after login. JWT_ACCESS_TOKEN_EXPIRE_MINUTES
# is accepted as an alternate name for the same setting (either works).
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -- Deployment / Monitoring / Backups -----------------------------------------
LOG_LEVEL=INFO
# Per-request access log line (method, path, status, duration, request id,
# user id if available). Never logs bodies, passwords, tokens, or API keys.
ENABLE_REQUEST_LOGGING=true
# Gates GET /api/v1/metrics (admin-only, simple JSON counters — not
# Prometheus). Off by default.
ENABLE_METRICS=false
# Gates GET /api/v1/system/backups/status. Does not itself schedule
# backups — run scripts/backup_db.* manually or via an external scheduler.
ENABLE_BACKUPS=false
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
HEALTHCHECK_TIMEOUT_SECONDS=5

# -- Rate Limits ----------------------------------------------------------------
# Protect expensive/sensitive endpoints (login, register, sales workflow,
# website research, LLM test, external draft creation, reply sync,
# do-not-contact check) from abuse. Applied per authenticated user (from
# the JWT) or per hashed IP otherwise — a raw IP is never stored or logged.
# Returns HTTP 429 with a Retry-After header once a limit is exceeded.
RATE_LIMIT_ENABLED=true
# "memory" (in-process, fine for a single instance) or "redis" (shared
# counters across multiple backend instances — falls back to memory with a
# logged warning, never a crash, if Redis is unreachable).
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_WORKFLOW_PER_HOUR=20
RATE_LIMIT_WEBSITE_RESEARCH_PER_HOUR=30
RATE_LIMIT_LLM_TEST_PER_HOUR=10
RATE_LIMIT_EXTERNAL_DRAFT_PER_HOUR=20
RATE_LIMIT_REPLY_SYNC_PER_HOUR=20
RATE_LIMIT_COMPLIANCE_CHECK_PER_MINUTE=60
RATE_LIMIT_LEAD_SOURCING_RUNS_PER_HOUR=10
RATE_LIMIT_LEAD_IMPORT_PER_HOUR=20
RATE_LIMIT_LEAD_QUALIFICATION_PER_HOUR=50
RATE_LIMIT_OUTREACH_QUEUE_PER_HOUR=20
RATE_LIMIT_OUTREACH_BATCH_PREP_PER_HOUR=10

# -- Audit Logs -------------------------------------------------------------------
# System-wide, append-only trail of security/compliance-relevant actions
# (login, workflow runs, review decisions, do-not-contact changes, external
# drafts, reply syncs, rate limit hits, ...). Never stores secrets, API
# keys, tokens, full email bodies, full LLM prompts, or full reply bodies —
# see README section "Audit Logs". Admin-only via GET /api/v1/audit-logs.
AUDIT_LOGS_ENABLED=true
# Informational only for now (no automatic purge job exists yet).
AUDIT_LOG_RETENTION_DAYS=180

# -- Email Draft Integration (Gmail/Outlook) -----------------------------------
# EMAIL_INTEGRATION_PROVIDER selects the backend: "mock" (default, fully
# offline, no external account touched) or "gmail"/"outlook" (creates a real
# draft in the connected account — never sends anything; there is no send
# capability anywhere in this integration).
EMAIL_INTEGRATION_PROVIDER=mock
# Safety switch: even with EMAIL_INTEGRATION_PROVIDER=gmail/outlook and its
# OAuth credentials set, no real provider call is ever made unless this is
# explicitly "true". Leave "false" for local development and demos. See
# README section "Gmail/Outlook Draft Integration" before ever setting this
# to true.
EMAIL_INTEGRATION_ENABLE_REAL_DRAFTS=false
# Only required when EMAIL_INTEGRATION_PROVIDER=gmail. Requests only the
# gmail.compose scope — never gmail.send. NEVER commit real values here or
# anywhere else in the repository.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Only required when EMAIL_INTEGRATION_PROVIDER=outlook. Requests only the
# Mail.ReadWrite scope — never Mail.Send.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
# Base URL the backend is reachable at, used to build the OAuth redirect
# (callback) URL: {OAUTH_REDIRECT_BASE_URL}/api/v1/integrations/email/{provider}/callback.
# Must match a redirect URI registered with Google/Microsoft.
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
# Symmetric key used to encrypt OAuth tokens at rest (never stored in
# plaintext). Only required when EMAIL_INTEGRATION_ENABLE_REAL_DRAFTS=true.
# Generate a real random secret for anything beyond a local sandbox (e.g.
# `openssl rand -hex 32`) and NEVER commit the real value.
EMAIL_TOKEN_ENCRYPTION_KEY=
EMAIL_DRAFT_MAX_SUBJECT_CHARS=200
EMAIL_DRAFT_MAX_BODY_CHARS=20000

# -- Reply Inbox / Reply Tracking (Gmail/Outlook) ------------------------------
# REPLY_TRACKING_PROVIDER selects the backend: "mock" (default, fully
# offline, generates sample replies) or "gmail"/"outlook" (reads real
# replies from the connected account — there is no send/reply capability
# anywhere in this integration; it only ever reads and stores).
REPLY_TRACKING_PROVIDER=mock
# Safety switch: even with REPLY_TRACKING_PROVIDER=gmail/outlook and its
# OAuth credentials set, no real mailbox is ever read unless this is
# explicitly "true". Leave "false" for local development and demos. See
# README section "Reply Inbox und Reply Tracking" before ever setting this
# to true. Reuses the same GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET,
# MICROSOFT_CLIENT_ID/MICROSOFT_CLIENT_SECRET/MICROSOFT_TENANT_ID, and
# EMAIL_TOKEN_ENCRYPTION_KEY as the Email Draft Integration above — no
# separate OAuth app registration needed, though Gmail requires the
# connected account to have granted a read scope (gmail.readonly or
# broader), not just gmail.compose.
REPLY_TRACKING_ENABLE_REAL_READS=false
# Upper bound on how many messages a single sync call reads.
REPLY_TRACKING_MAX_MESSAGES_PER_SYNC=25
# How far back (in days) a sync call looks for replies.
REPLY_TRACKING_LOOKBACK_DAYS=30
REPLY_TRACKING_TIMEOUT_SECONDS=30
# When true (default), only a short body preview is stored for each
# reply — the full message body is discarded after analysis.
REPLY_TRACKING_STORE_BODY_PREVIEW_ONLY=true

# -- Website Research ---------------------------------------------------------
# Fetches only the exact public URL a caller supplies via POST
# /api/v1/research/website — no automatic mass research, no LinkedIn
# scraping, no LLM call. localhost/private/internal targets are always
# blocked regardless of these settings (see backend/infrastructure/web/).
# How long to wait for a response before giving up.
WEBSITE_FETCH_TIMEOUT_SECONDS=10
# Maximum response body size, in bytes, read from any single fetched page.
WEBSITE_FETCH_MAX_BYTES=2000000
# Reserved for a future same-domain crawl; only 1 page is fetched today
# regardless of this value or what a caller requests.
WEBSITE_RESEARCH_MAX_PAGES=1
# Sent as the User-Agent header on every fetch, so site owners can identify
# and, if needed, block this tool.
WEBSITE_RESEARCH_USER_AGENT=AI-Sales-Agent-WebsiteResearch/1.0

# -- Lead Sourcing --------------------------------------------------------------
# Finds and scores potential customers against an ICP. No LinkedIn
# scraping, no scraping behind a login, no CAPTCHA bypass, no guessing
# personal email addresses. A candidate only ever becomes a CRM Company/
# Lead once a human explicitly approves it. "mock" needs no external call
# and no secrets; "search_api" is a safe-mode structure only in this
# project (no real client is wired in) and always falls back to "mock"
# unless LEAD_SOURCING_ENABLE_REAL_SEARCH=true is explicitly set.
LEAD_SOURCING_PROVIDER=mock
LEAD_SOURCING_ENABLE_REAL_SEARCH=false
LEAD_SOURCING_MAX_RESULTS_PER_RUN=25
LEAD_SOURCING_MAX_WEBSITE_PAGES_PER_COMPANY=2
LEAD_SOURCING_REQUEST_TIMEOUT_SECONDS=30
# Extracts a contact email only from text already rendered on the public
# page fetched via Website Research — never a new/separate scrape.
LEAD_SOURCING_ALLOW_PUBLIC_WEBSITE_EMAIL_EXTRACTION=true
# When false, only role-based addresses (info@, sales@, contact@, ...) are
# kept; anything that looks like a named individual's address is dropped.
LEAD_SOURCING_ALLOW_PERSONAL_EMAILS=false
# When true, a candidate only becomes a CRM Company/Lead once a human
# explicitly approves it via POST /candidates/{id}/approve.
LEAD_SOURCING_REQUIRE_REVIEW_BEFORE_CRM=true

# -- Lead Qualification & Scoring -----------------------------------------------
# Scores and prioritizes Lead Candidates/CRM Leads. Always rule-based by
# default (no LLM call at all); the optional advisor below only ever
# improves wording, never the score itself, and only makes a real LLM
# call when LLM_PROVIDER=anthropic and LLM_ENABLE_REAL_CALLS=true are
# both already set for the whole app.
LEAD_QUALIFICATION_ENABLED=true
LEAD_QUALIFICATION_DEFAULT_MIN_SCORE=70
LEAD_QUALIFICATION_PRIORITY_SCORE=85
LEAD_QUALIFICATION_DISQUALIFY_SCORE=40
# When true, qualifying without an ICP profile (and no prior ICP fit data
# on the candidate) is rejected with a clear error instead of a warning.
LEAD_QUALIFICATION_REQUIRE_ICP=false
# Reuses the existing, SSRF-guarded Website Research service — never a
# new kind of fetch.
LEAD_QUALIFICATION_USE_WEBSITE_RESEARCH=true
# Wording-only LLM advisor (fit_summary / recommended_outreach_angle /
# missing_data notes). Mock provider is the default; a real call only
# ever happens when LLM_ENABLE_REAL_CALLS=true is set app-wide — that is
# a billable, real API call once enabled, so leave this false unless you
# intend to opt in.
LEAD_QUALIFICATION_USE_LLM=false
LEAD_QUALIFICATION_MAX_NOTES_CHARS=4000

# -- Outreach Campaign Queue -----------------------------------------------------
# Collects already-qualified leads into a prioritized, campaign-scoped queue
# for human review. Never sends an email, never contacts anyone, and never
# creates an external (Gmail/Outlook) draft by itself — every queue item
# only ever moves forward through a deliberate, human-triggered action.
OUTREACH_QUEUE_ENABLED=true
OUTREACH_QUEUE_DEFAULT_MIN_SCORE=70
OUTREACH_QUEUE_DEFAULT_BATCH_SIZE=10
OUTREACH_QUEUE_MAX_BATCH_SIZE=25
# When true, a Lead Candidate/CRM Lead without a qualification result is
# skipped rather than queued with an unknown score.
OUTREACH_QUEUE_REQUIRE_QUALIFICATION=true
# Human Review is never bypassed regardless of this flag — it only
# documents the requirement for the status/UI layer.
OUTREACH_QUEUE_REQUIRE_HUMAN_REVIEW=true
# Allows Batch Preparation, which prepares internal Sales Workflow runs/
# email drafts for several queue items at once. Never creates an external
# draft and never sends anything, regardless of this flag.
OUTREACH_QUEUE_ALLOW_BATCH_WORKFLOW_PREP=true
# Must stay false: nothing in this feature ever creates an external draft
# automatically. External drafts remain a fully separate, manual action via
# the existing Email Draft Integration (Gmail/Outlook) flow.
OUTREACH_QUEUE_AUTO_CREATE_EXTERNAL_DRAFTS=false

# -- Controlled Outreach Dispatch -------------------------------------------------
# Processes already-approved Outreach Queue items into a controlled external
# draft, or — only when explicitly enabled — a manually confirmed send.
# draft_only is the default and safe mode. Real sending requires
# OUTREACH_DISPATCH_MODE=manual_send AND OUTREACH_DISPATCH_ENABLE_REAL_SEND=true
# AND a human's compliance acknowledgement AND final confirmation. No send
# scope is ever requested from Gmail/Outlook in this codebase, so even with
# real send "enabled", those providers always report a safe-mode message —
# only the mock provider ever simulates a confirmed send.
OUTREACH_DISPATCH_ENABLED=true
OUTREACH_DISPATCH_MODE=draft_only
OUTREACH_DISPATCH_PROVIDER=mock
OUTREACH_DISPATCH_ENABLE_REAL_SEND=false
OUTREACH_DISPATCH_REQUIRE_FINAL_CONFIRMATION=true
OUTREACH_DISPATCH_REQUIRE_APPROVED_REVIEW=true
OUTREACH_DISPATCH_REQUIRE_DO_NOT_CONTACT_CHECK=true
OUTREACH_DISPATCH_REQUIRE_COMPLIANCE_ACK=true
OUTREACH_DISPATCH_MAX_PER_DAY=25
OUTREACH_DISPATCH_MAX_PER_HOUR=10
OUTREACH_DISPATCH_BATCH_MAX_SIZE=5
RATE_LIMIT_OUTREACH_DISPATCH_PER_HOUR=10

# -- Customer Onboarding / Admin Controls -----------------------------------------
# Seed values for a workspace's default settings record and app-wide safety
# defaults surfaced in Onboarding Readiness. These never substitute for the
# provider-specific *_ENABLE_REAL_* flags above, which remain the sole
# authority over whether a real provider call can ever happen.
DEMO_MODE=false
DEFAULT_WORKSPACE_NAME=AI Sales Agent Workspace
DEFAULT_LANGUAGE=de
DEFAULT_TONE=professional
REQUIRE_HUMAN_REVIEW=true
REQUIRE_DO_NOT_CONTACT_CHECK=true

# -- Legal/Compliance Pack: Data Retention ----------------------------------------
# Disabled by default. Even when enabled, a real (non-dry-run) retention run
# anonymizes rather than deletes unless a policy explicitly overrides that.
# See COMPLIANCE.md and CUSTOMER_READINESS.md — none of this is legal advice.
DATA_RETENTION_ENABLED=false
DATA_RETENTION_LEADS_DAYS=365
DATA_RETENTION_COMPANIES_DAYS=365
DATA_RETENTION_EMAIL_DRAFTS_DAYS=180
DATA_RETENTION_REPLIES_DAYS=180
DATA_RETENTION_WORKFLOW_RUNS_DAYS=180
DATA_RETENTION_AUDIT_LOGS_DAYS=180
DATA_RETENTION_DO_NOT_CONTACT_DAYS=1095
DATA_RETENTION_EXTERNAL_DRAFTS_DAYS=180
DATA_RETENTION_BACKUP_DAYS=30
DATA_RETENTION_DRY_RUN_DEFAULT=true
DATA_RETENTION_ANONYMIZE_INSTEAD_OF_DELETE=true
