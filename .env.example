# Application
APP_NAME="AI Sales Agent"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# PostgreSQL
POSTGRES_USER=sales_agent
POSTGRES_PASSWORD=sales_agent_password
POSTGRES_DB=sales_agent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# LLM / AI Agents
# LLM_PROVIDER selects the backend: "mock" (default, no network) or "anthropic".
LLM_PROVIDER=mock
# Only required when LLM_PROVIDER=anthropic. Leave empty otherwise — never commit a real key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=1024

# Frontend / CORS
# Comma-separated list of origins allowed to call this API from a browser.
CORS_ALLOWED_ORIGINS=http://localhost:3000
