# Copy this file to ".env" and adjust as needed. Never commit the real ".env" —
# it is already covered by .gitignore. This file must only ever contain
# placeholder/example values, never real secrets.

# -- Application ------------------------------------------------------------
APP_NAME="AI Sales Agent"
# APP_ENV ("environment"): development | staging | production.
# Controls debug verbosity and the CORS wildcard-origin safety warning below.
APP_ENV=development
# DEBUG=true enables SQL echo, verbose (DEBUG-level) logs, and FastAPI's debug
# mode. Always set DEBUG=false in production.
DEBUG=true
# API_V1_PREFIX: URL prefix under which all v1 routes are mounted.
API_V1_PREFIX=/api/v1

# -- PostgreSQL ---------------------------------------------------------------
# The async SQLAlchemy connection URL is derived from these individual
# variables (see backend/shared/config.py: Settings.database_url) rather than
# a single DATABASE_URL, so each part can be swapped independently (e.g. for
# a managed Postgres host in production).
POSTGRES_USER=sales_agent
POSTGRES_PASSWORD=sales_agent_password
POSTGRES_DB=sales_agent
# Docker Compose service name; use "localhost" when running the backend
# directly on the host against `docker compose up postgres`.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -- Redis ----------------------------------------------------------------
# Same pattern as Postgres: individual variables combine into Settings.redis_url.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# -- LLM / AI Agents --------------------------------------------------------
# LLM_PROVIDER selects the backend: "mock" (default, fully offline, no cost)
# or "anthropic" (real model calls, incurs API cost).
LLM_PROVIDER=mock
# Only required when LLM_PROVIDER=anthropic. Leave empty otherwise.
# NEVER commit a real key here or anywhere else in the repository.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=1024

# -- Frontend / CORS ----------------------------------------------------------
# Comma-separated list of origins allowed to call this API from a browser.
# Must NOT be "*" in production — the backend logs a warning at startup if
# APP_ENV=production and this is left wildcarded.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -- Auth (local JWT) ---------------------------------------------------------
# No external auth provider and no OAuth in this phase — accounts, password
# hashing, and JWT access tokens are fully local to this backend.
# JWT_SECRET_KEY signs access tokens. The default below is a placeholder for
# local development ONLY — generate a real random secret for anything beyond
# a local sandbox (e.g. `openssl rand -hex 32`) and NEVER commit the real
# value. The backend logs a warning at startup if this default is still set
# while APP_ENV=production.
JWT_SECRET_KEY=dev-only-insecure-secret-change-me
JWT_ALGORITHM=HS256
# How long an access token stays valid after login.
ACCESS_TOKEN_EXPIRE_MINUTES=60
