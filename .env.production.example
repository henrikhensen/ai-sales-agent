# Production environment template — for a real deployment (Railway or any
# other host), not local development. Copy the *values* you need into your
# host's environment-variable UI (e.g. Railway service → Variables tab).
# NEVER commit a file with real values filled in — this file only ever
# contains placeholders. See `.env.example` for the full list of every
# variable this backend understands (feature flags, rate limits, etc.) with
# its local-dev default; this file only lists the ones that change, or must
# be deliberately set, for a real production deployment. See
# `DEPLOYMENT_RAILWAY.md` for the exact Railway click-path.

# -- Application --------------------------------------------------------------
APP_NAME="AI Sales Agent"
APP_VERSION=0.1.0
# Must be exactly "production" — the backend hard-fails startup (refuses to
# serve traffic) if JWT_SECRET_KEY/POSTGRES_PASSWORD are still dev defaults
# or CORS_ALLOWED_ORIGINS is empty/"*" while this is "production".
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
# Your real Railway-issued (or custom) domains. Informational only (shown in
# GET /api/v1/system/status) — does not affect CORS, which is configured
# separately below.
FRONTEND_PUBLIC_URL=https://REPLACE-WITH-YOUR-FRONTEND-DOMAIN
BACKEND_PUBLIC_URL=https://REPLACE-WITH-YOUR-BACKEND-DOMAIN

# -- PostgreSQL -----------------------------------------------------------------
# REQUIRED. Railway's Postgres plugin publishes a single connection string —
# set DATABASE_URL to it (Railway: reference it as
# ${{Postgres.DATABASE_URL}} in the backend service's Variables tab so it
# stays in sync automatically). DATABASE_URL always takes precedence over
# the individual POSTGRES_* vars below when set, so leave those unset.
DATABASE_URL=

# -- Redis (optional) -------------------------------------------------------------
# Optional on Railway: rate limiting already falls back to an in-memory
# counter if Redis is unreachable or unset (fine for a single backend
# instance). Add Railway's Redis plugin and set this only if you need
# shared rate-limit counters across multiple backend instances, or want
# GET /ready to report Redis as "up".
REDIS_URL=

# -- LLM / AI Agents ------------------------------------------------------------
# Stay on mock until you deliberately decide to pay for real model calls.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
LLM_ENABLE_REAL_CALLS=false

# -- Frontend / CORS --------------------------------------------------------------
# REQUIRED. Exact frontend origin(s), comma-separated if more than one.
# Never "*" — the backend refuses to start otherwise (see APP_ENV above).
CORS_ALLOWED_ORIGINS=https://REPLACE-WITH-YOUR-FRONTEND-DOMAIN

# -- Auth (local JWT) ---------------------------------------------------------------
# REQUIRED. Generate with `openssl rand -hex 32` (or
# `python -c "import secrets;print(secrets.token_hex(32))"`) — never reuse
# the local-dev placeholder, never commit the real value.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -- Deployment / Monitoring ----------------------------------------------------
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true
ENABLE_METRICS=false
ENABLE_BACKUPS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=memory
AUDIT_LOGS_ENABLED=true

# -- Email Draft Integration / Reply Tracking (kept disabled by default) --------
# This project's real-provider gate: a provider name alone is never enough
# to send/read anything real — the matching *_ENABLE_REAL_* flag must also
# be explicitly "true". Leave both providers "mock" and both flags "false"
# for a first public deployment; there is no send capability regardless.
EMAIL_INTEGRATION_PROVIDER=mock
EMAIL_INTEGRATION_ENABLE_REAL_DRAFTS=false
REPLY_TRACKING_PROVIDER=mock
REPLY_TRACKING_ENABLE_REAL_READS=false

# -- Lead Sourcing (kept on the safe mock provider by default) ------------------
LEAD_SOURCING_PROVIDER=mock
LEAD_SOURCING_ENABLE_REAL_SEARCH=false
BRAVE_SEARCH_API_KEY=

# -- Controlled Outreach Dispatch (kept in draft-only mode by default) ----------
# draft_only is the only mode with a Railway launch in mind; never set
# OUTREACH_DISPATCH_MODE=manual_send / OUTREACH_DISPATCH_ENABLE_REAL_SEND=true
# here — real sending is out of scope for this deployment.
OUTREACH_DISPATCH_MODE=draft_only
OUTREACH_DISPATCH_PROVIDER=mock
OUTREACH_DISPATCH_ENABLE_REAL_SEND=false
