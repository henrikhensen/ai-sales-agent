# Copy this file to ".env.local" for local `npm run dev` usage. Never commit
# the real ".env.local" — it is already covered by frontend/.gitignore.
#
# Only add NEXT_PUBLIC_* variables here — anything with that prefix is
# bundled into the browser JavaScript and is NOT a place for secrets. This
# frontend calls the backend directly from the browser and holds no API
# keys or other secrets of its own.

# Must be reachable from the BROWSER, not from inside a Docker network — so
# this is the backend's published host port, not an internal container name.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
